{"name":"SQF","icon":"game","settings":"{\"settings\":\"{\\n    /*\\n        FROM DEFAULT PROFILE\\n    */\\n    // If you need to include something to all profiles automatically, edit the Default Profile.\\n    /*\\n        SPECIFIC FOR THIS PROFILE\\n    */\\n    // CUSTOM IDE UI  - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"editor.renderWhitespace\\\": \\\"all\\\",\\n    \\\"breadcrumbs.enabled\\\": true,\\n    \\\"workbench.statusBar.visible\\\": true,\\n    \\\"editor.wordWrap\\\": \\\"on\\\",\\n    \\\"editor.hover.delay\\\": 2000, // default 300\\n    \\\"editor.inlayHints.enabled\\\": \\\"off\\\",\\n    // CUSTOM THEME - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"workbench.colorCustomizations\\\": {\\n        \\\"editor.selectionBackground\\\": \\\"#E5FFE6\\\",\\n        \\\"editor.selectionHighlightBackground\\\": \\\"#e5ffe641\\\",\\n        \\\"editor.findMatchBackground\\\": \\\"#818181\\\", //Current SEARCH MATCH\\n        \\\"editor.findMatchHighlightBackground\\\": \\\"#81818128\\\" //Other SEARCH MATCHES\\n    },\\n    \\\"editor.tokenColorCustomizations\\\": {\\n        \\\"[Atom One Dark]\\\": {\\n            \\\"variables\\\": \\\"#eb54de\\\",\\n            \\\"functions\\\": \\\"#ff9b58\\\",\\n            \\\"numbers\\\": \\\"#49f5b3\\\",\\n            \\\"strings\\\": \\\"#70fa20\\\",\\n            \\\"keywords\\\": \\\"#fc6620\\\",\\n            \\\"comments\\\": \\\"#505050\\\",\\n            \\\"types\\\": \\\"#0004ff\\\",\\n            \\\"textMateRules\\\": [\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"constant.other\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#1400c4\\\"\\n                    }\\n                },\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"support.function\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#fff5cb\\\",\\n                        \\\"fontStyle\\\": \\\"italic\\\"\\n                    }\\n                },\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"keyword.operator\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#7ee9fc\\\",\\n                        \\\"fontStyle\\\": \\\"bold\\\"\\n                    }\\n                },\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"variable.language\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#a13140\\\"\\n                    }\\n                },\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"meta.function-call\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#fc6620\\\"\\n                    }\\n                },\\n                {\\n                    \\\"scope\\\": [\\n                        \\\"punctuation.terminator\\\"\\n                    ],\\n                    \\\"settings\\\": {\\n                        \\\"foreground\\\": \\\"#ffffff\\\"\\n                    }\\n                },\\n            ]\\n        }\\n    },\\n    \\\"editor.semanticTokenColorCustomizations\\\": {\\n        \\\"[Atom One Dark]\\\": {\\n            \\\"enabled\\\": true,\\n            \\\"rules\\\": {\\n                \\\"*.declaration\\\": {\\n                    \\\"bold\\\": true\\n                }\\n            }\\n        }\\n    },\\n    // LINTER, FORMATTER, TYPE-CHECKER - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Try to set this only in: your_project/.vscode/settings.json\\n    // CUSTOM TERMINAL - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM SECURITY - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM PROJECTS SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false, // Avoid code suggestion during the coding with autocompletetion!\\n    },\\n    \\\"editor.quickSuggestions\\\": {\\n        \\\"other\\\": \\\"on\\\",\\n        \\\"comments\\\": \\\"on\\\",\\n        \\\"strings\\\": \\\"on\\\"\\n    },\\n    // CUSTOM TXT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Just configured in Default (Application Settings)!\\n    // CUSTOM C++ SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM SQF SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    \\\"sqf.enableCBA\\\": true,\\n    \\\"sqf.enableACE3\\\": true,\\n    \\\"C_Cpp.autocompleteAddParentheses\\\": true,\\n    \\\"sqflint.checkPaths\\\": true,\\n    \\\"sqflint.warnings\\\": false,\\n    // WHAT IS IT?\\n    \\\"editor.semanticHighlighting.enabled\\\": true,\\n    \\\"cmake.parseBuildDiagnostics\\\": false,\\n    // CUSTOM HTML & CSS:\\n    // Reserved space...\\n    // FILES - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    \\\"files.associations\\\": {\\n        \\\"*.hpp\\\": \\\"cpp\\\", // C++\\n        \\\"*.sqm\\\": \\\"sqm\\\",\\n        \\\"*.sqf\\\": \\\"sqf\\\",\\n    },\\n    // LANGUAGE, DICTIONARY STUFF - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    // Reserved space...\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+alt+f12\\\",\\n        \\\"command\\\": \\\"codesnap.start\\\"\\n    }\\n]\",\"platform\":2}","snippets":"{\"snippets\":{\"sqf.json\":\"{\\n\\t// Place your snippets for sqf here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"akamud.vscode-theme-onedark\",\"uuid\":\"9b2c953d-6ad4-46d1-b18e-7e5992d1d8a6\"},\"displayName\":\"Atom One Dark Theme\",\"applicationScoped\":true},{\"identifier\":{\"id\":\"armitxes.sqf\",\"uuid\":\"c612fc7d-8fe9-43d0-9b8f-1203df49b649\"},\"displayName\":\"SQF Language\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"billw2011.sqf-debugger\",\"uuid\":\"79de2fa9-9041-4704-93a5-3a1941f2e2d7\"},\"displayName\":\"SQF Debugger\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"blackfisch.sqf-language\",\"uuid\":\"7a065776-a69a-46b3-aa1b-f38345b97578\"},\"displayName\":\"Arma SQF Language\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"eelislynne.sqf-wiki\",\"uuid\":\"53576cd4-a83f-48f2-8269-17c8923ef96d\"},\"displayName\":\"SQF Wiki\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"github.copilot-chat\",\"uuid\":\"7ec7d6e6-b89e-4cc5-a59b-d6c4d238246f\"},\"displayName\":\"GitHub Copilot Chat\",\"applicationScoped\":true},{\"identifier\":{\"id\":\"github.remotehub\",\"uuid\":\"fc7d7e85-2e58-4c1c-97a3-2172ed9a77cd\"},\"displayName\":\"GitHub Repositories\",\"applicationScoped\":true},{