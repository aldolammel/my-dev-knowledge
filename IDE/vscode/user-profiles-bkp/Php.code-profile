{"name":"Php","icon":"vscode","settings":"{\"settings\":\"{\\n    /*\\n        FROM DEFAULT PROFILE\\n    */\\n    // If you need to include something to all profiles automatically, edit the Default Profile.\\n    /*\\n        SPECIFIC FOR THIS PROFILE\\n    */\\n    // CUSTOM IDE UI  - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"breadcrumbs.enabled\\\": true,\\n    \\\"workbench.statusBar.visible\\\": true,\\n    \\\"chat.viewSessions.enabled\\\": false,\\n    \\\"chat.agent.thinkingStyle\\\": \\\"collapsed\\\",\\n    // \\\"editor.wordWrap\\\": \\\"on\\\",\\n    \\\"editor.hover.delay\\\": 2000, // default 300\\n    // CUSTOM THEME - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"editor.tokenColorCustomizations\\\": { // Color of the comments like docstring.\\n        \\\"textMateRules\\\": [\\n            {\\n                \\\"scope\\\": \\\"string.quoted.docstring.multi.python\\\",\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#535353\\\"\\n                }\\n            }\\n        ]\\n    },\\n    // LINTER, FORMATTER, TYPE-CHECKER - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Try to set this only in: your_project/.vscode/settings.json\\n    // CUSTOM TERMINAL - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM SECURITY - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM PROJECTS SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false, // Avoid code suggestion during the coding with autocompletetion!\\n    },\\n    \\\"editor.quickSuggestions\\\": {\\n        \\\"other\\\": \\\"on\\\",\\n        \\\"comments\\\": \\\"on\\\",\\n        \\\"strings\\\": \\\"on\\\"\\n    },\\n    // CUSTOM TXT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Just configured in Default (Application Settings)!\\n    // CUSTOM PHP SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM JAVASCRIPT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"[javascript]\\\": {\\n        \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\",\\n        \\\"editor.tabSize\\\": 2,\\n        \\\"editor.indentSize\\\": \\\"tabSize\\\",\\n        \\\"editor.insertSpaces\\\": true,\\n    },\\n    // CUSTOM JSON SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    \\\"[jsonc]\\\": {\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.json-language-features\\\", // VSCode\\n    },\\n    // CUSTOM HTML SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    // Reserved space...\\n    // CUSTOM CSS SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // CUSTOM VUE SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    // Reserved space...\\n    // FILES - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\n    \\\"files.associations\\\": {\\n        \\\"*.php\\\": \\\"php\\\",\\n        \\\"*.phtml\\\": \\\"php\\\", // PHP template files\\n        \\\"*.php.dist\\\": \\\"php\\\" // Configuration distro files\\n    },\\n    // LANGUAGE, DICTIONARY STUFF - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\n    // Reserved space...\\n}\"}","extensions":"[{\"identifier\":{\"id\":\"akamud.vscode-theme-onedark\",\"uuid\":\"9b2c953d-6ad4-46d1-b18e-7e5992d1d8a6\"},\"displayName\":\"Atom One Dark Theme\",\"applicationScoped\":true},{\"identifier\":{\"id\":\"bmewburn.vscode-intelephense-client\",\