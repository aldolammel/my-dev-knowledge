// file: /project_root/.vscode/settings.json
{
    /*
        VSCODE SPECIFIC SETTINGS FOR PROJECT: <CLIENT_NAME> <PRODUCT TYPE OR NAME> <YEAR RELEASE>
    */
    // PROJECT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    "editor.formatOnSave": true, // Automatically formats the current file (all types) in saving.
    "editor.rulers": [
        100 // Draw ruler at column XXX.
    ],
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 100,
    // TXT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    "[plaintext]": {
        "editor.lineNumbers": "off",
        "editor.trimAutoWhitespace": false,
        "editor.guides.indentation": false,
    },
    "[markdown]": { // Bugged (2026/april)
        // This shit (editor.wordWrap) doesn't work if declared in Default Profile or Profile. It must be in project AND inside the markdown tag!
        "editor.wordWrap": "wordWrapColumn",
        "editor.lineNumbers": "off",
        "editor.trimAutoWhitespace": true,
        "editor.guides.indentation": true,
    },
    // FILE - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    // Tell VSCode how to treat files based on patterns:
    "files.associations": {
        //...
    },
    // Files/folders to hide from the VSCode explorer:
    "files.exclude": {
        // "**/venv": true,
        // "**/.venv": true,
        // "**/.git": true,
    },
    // Files/folders to hide from VSCode searches:
    "search.exclude": {
        "**/venv": true,
        "**/.venv": true,
        "**/.git": true,
    },
    // HUMAN LANGUAGE, DICTIONARY STUFF - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    // Reserved space...
}