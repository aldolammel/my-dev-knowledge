{"name":"Python+XML","icon":"vscode","settings":"{\"settings\":\"{\\r\\n    /*\\r\\n        FROM DEFAULT PROFILE\\r\\n    */\\r\\n    // If you need to include something to all profiles automatically, edit the Default Profile.\\r\\n    /*\\r\\n        SPECIFIC FOR THIS PROFILE\\r\\n    */\\r\\n    // CUSTOM IDE UI  - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\r\\n    \\\"breadcrumbs.enabled\\\": true,\\r\\n    \\\"workbench.statusBar.visible\\\": true,\\r\\n    \\\"chat.viewSessions.enabled\\\": false,\\r\\n    \\\"chat.agent.thinkingStyle\\\": \\\"collapsed\\\",\\r\\n    // \\\"editor.wordWrap\\\": \\\"on\\\",\\r\\n    \\\"editor.hover.delay\\\": 2000, // default 300\\r\\n    // CUSTOM THEME - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\r\\n    \\\"editor.tokenColorCustomizations\\\": { // Color of the comments like docstring.\\r\\n        \\\"textMateRules\\\": [\\r\\n            {\\r\\n                \\\"scope\\\": \\\"string.quoted.docstring.multi.python\\\",\\r\\n                \\\"settings\\\": {\\r\\n                    \\\"foreground\\\": \\\"#535353\\\"\\r\\n                }\\r\\n            }\\r\\n        ]\\r\\n    },\\r\\n    // LINTER, FORMATTER, TYPE-CHECKER - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    // Try to set this only in: your_project/.vscode/settings.json\\r\\n    // CUSTOM TERMINAL - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    // Reserved space...\\r\\n    // CUSTOM SECURITY - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    // Reserved space...\\r\\n    // CUSTOM PROJECTS SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\r\\n    \\\"editor.formatOnSave\\\": true,\\r\\n    \\\"github.copilot.enable\\\": {\\r\\n        \\\"*\\\": false, // Avoid code suggestion during the coding with autocompletetion!\\r\\n    },\\r\\n    \\\"editor.quickSuggestions\\\": {\\r\\n        \\\"other\\\": \\\"on\\\",\\r\\n        \\\"comments\\\": \\\"on\\\",\\r\\n        \\\"strings\\\": \\\"on\\\"\\r\\n    },\\r\\n    // CUSTOM TXT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    // Just configured in Default (Application Settings)!\\r\\n    // CUSTOM PYTHON SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\r\\n    \\\"python.languageServer\\\": \\\"Pylance\\\", // Python language server.\\r\\n    \\\"python.analysis.typeCheckingMode\\\": \\\"standard\\\", // Python Type-checker.\\r\\n    \\\"[python]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"charliermarsh.ruff\\\", // Ruff Linter/Formatter\\r\\n        //\\\"editor.formatOnSave\\\": true, // It's already set in projects settings in this file!\\r\\n        \\\"editor.codeActionsOnSave\\\": {\\r\\n            \\\"source.fixAll.ruff\\\": \\\"always\\\", // Ruff Linter/Formatter\\r\\n            \\\"source.organizeImports.ruff\\\": \\\"always\\\", // Ruff Linter/Formatter\\r\\n        }\\r\\n    },\\r\\n    // CUSTOM XML SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    // Reserved space...\\r\\n    // FILES - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\\r\\n    \\\"files.associations\\\": {\\r\\n        \\\"*.py\\\": \\\"python\\\",\\r\\n        \\\"*.pyi\\\": \\\"python\\\", // Type stub files\\r\\n        \\\"*.toml\\\": \\\"toml\\\", // pyproject.toml, poetry, etc.\\r\\n        \\\"*.cfg\\\": \\\"ini\\\", // setup.cfg, pytest.ini style configs\\r\\n        \\\"*.ini\\\": \\\"ini\\\", // General config files\\r\\n        \\\"*.env\\\": \\\"dotenv\\\", // Environment variables\\r\\n        \\\".env.*\\\": \\\"dotenv\\\", // .env.development, .env.production, etc.\\r\\n        \\\"*.json\\\": \\\"json\\\",\\r\\n        \\\"*.jsonc\\\": \\\"jsonc\\\",\\r\\n    },\\r\\n    // LANGUAGE, DICTIONARY STUFF - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - \\r\\n    // Reserved space...\\r\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"numpad_divide\\\",\\n        \\\"command\\\": \\\"workbench.action.openSettingsJson\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+alt+f12\\\",\\n        \\\"command\\\": \\\"codesnap.start\\\"\\n    }\\n]\",\"platform\":2}","snippets":"{\"snippets\":{\"sqf.json\":\"{\\n\\t// Place your snippets for sqf here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"akamud.vscode-theme-onedark\",\"uuid\":\"9b2c953d-6ad4-46d1-b18e-7e5992d1d8a6\"},\"displayName\":\"Atom One Dark Theme\",\"applicationScoped\":true},{\"identifier\":{\"id\":\"charliermarsh.ruff\",\"uuid\":\"c2ca9b43-fa38-44fc-928e-5125970b9c00\"},\"displayName\":\"Ruff\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"dotjoshjohnson.xml\",\"uuid\":\"0cb81da2-1880-4755-9995-0ae9cc728e20\"},\"displayName\":\"XML Tools\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"ecmel.vscode-html-css\",\"uuid\":\"aaee577c-f062-495a-9816-0cbd442f1d25\"},\"displayName\":\"HTML CSS Support\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"github.copilot-chat\",\"uuid\":\"7ec7d6e6-b89e-4cc5-a59b-d6c4d238246f\"},\"display