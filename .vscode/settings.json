{
    /*
        VSCODE SETTINGS FOR PROJECT: MY-DEV-KNOWLEDGE
    */
    // PROJECT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    "editor.formatOnSave": true, // Automatically formats the current file (all types) in saving.
    "editor.rulers": [
        100
    ],
    "editor.wordWrap": "wordWrapColumn", //"on"  // to respect only the screen edge.
    "editor.wordWrapColumn": 100,
    "prettier.printWidth": 100, // Prettier
    // TXT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    "[markdown]": { // Bugged (2026/april)
        // This shit doesn't work if declared in Default Profile or Profile. It must be in project!
        "editor.wordWrap": "wordWrapColumn",
    },
    // JAVASCRIPT SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode", // Prettier
        "editor.tabSize": 2,
        "editor.indentSize": "tabSize",
        "editor.insertSpaces": true,
    },
    // JSON SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode", // Prettier
    },
    // HTML SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    "html.format.wrapLineLength": 100,
    "html.format.indentInnerHtml": true,
    "html.format.templating": true,
    "html.format.maxPreserveNewLines": 2,
    // CSS SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode", // Prettier
        "editor.tabSize": 2,
        "editor.indentSize": "tabSize",
        "editor.insertSpaces": true,
    },
    // VUE SETTINGS - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    "[vue]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode", // Prettier
        "editor.tabSize": 2,
        "editor.indentSize": "tabSize",
        "editor.insertSpaces": true,
    },
    // FILES - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
    "files.associations": {
        "*.css": "css",
        "*.vue": "vue",
        "*.json": "jsonc",
        "*.txt": "plaintext",
        "*.text": "plaintext",
        "README": "plaintext",
        "CHANGELOG": "plaintext",
        "LICENSE": "plaintext",
        "*.log": "plaintext"
    },
    // Files/folders to hide from the VSCode explorer:
    "files.exclude": {
        "**/venv": true,
        "**/.venv": true,
        "**/venv_studies": true,
        "**/.venv_studies": true,
    },
    // Files/folders to hide from the VSCode searchings:
    "search.exclude": {
        "**/venv": true,
        "**/venv_studies": true,
        "**/.venv": true,
        "**/.venv_studies": true,
        "**/.git": true,
    },
    // HUMAN LANGUAGE, DICTIONARY STUFF:
    // Never in project, always in the developer profiles!
}